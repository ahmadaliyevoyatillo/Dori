<%- include('layout/header') %>

<div class="page-view" style="text-align: center; padding: 5rem 2rem;">
  <div style="font-size: 6rem; font-weight: 800; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 1rem;">404</div>
  <h1 style="font-size: 1.8rem; margin-bottom: 1rem;"><%= lang === 'en' ? 'Page Not Found' : 'Sahifa topilmadi' %></h1>
  <p style="color: var(--text-muted); font-size: 1.05rem; margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
    <%= lang === 'en' ? 'The page you are looking for does not exist or has been moved.' : "Siz izlayotgan sahifa mavjud emas yoki ko'chirilgan." %>
  </p>
  <a href="/" class="login-trigger-btn" style="display: inline-flex; text-decoration: none;">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
    <span><%= lang === 'en' ? 'Go to Home Page' : 'Bosh sahifaga qaytish' %></span>
  </a>
</div>

<%- include('layout/footer') %>
