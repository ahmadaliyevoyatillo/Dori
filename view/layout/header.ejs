<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Dori.uz Tibbiy Portali</title>
  <meta name="description" content="Tibbiy dori-darmonlar va kasalliklar haqidagi to'liq ma'lumotlar bazasi, taqqoslash va qidiruv portali.">
  <link rel="stylesheet" href="/style.css">
  
  <!-- "Flash of Light Mode" ning oldini olish uchun boshlang'ich skript -->
  <script>
    (function() {
      const cookies = document.cookie.split(';');
      let theme = 'light';
      for (let i = 0; i < cookies.length; i++) {
        const c = cookies[i].trim();
        if (c.startsWith('theme=')) {
          theme = c.substring('theme='.length);
          break;
        }
      }
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
        document.addEventListener("DOMContentLoaded", () => {
          document.body.classList.add('dark');
        });
      }
    })();
  </script>
</head>
<body class="<%= theme === 'dark' ? 'dark' : '' %>">

  <!-- --- NAVBAR SHELLI --- -->
  <header class="navbar-wrapper">
    <div class="navbar">
      <!-- Logo -->
      <a href="/" class="logo-container" id="nav-logo">
        <div class="logo-icon">D</div>
        <span class="logo-text">Dori.uz</span>
      </a>

      <!-- Qidiruv paneli -->
      <div class="nav-search-bar">
        <svg class="nav-search-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" class="nav-search-input" id="nav-search-input" placeholder="<%= lang === 'uz' ? 'Dori yoki kasallikni qidiring...' : 'Search medicine or disease...' %>" autocomplete="off">
        
        <!-- Dinamik Qidiruv Takliflari (Suggestions dropdown) -->
        <div class="search-suggestions" id="nav-search-suggestions"></div>
      </div>

      <!-- Sahifalar Navigatsiyasi -->
      <nav>
        <ul class="nav-links" id="nav-menu">
          <li><a href="/" class="nav-link" id="link-home"><%= t('nav_home') %></a></li>
          <li><a href="/medicines" class="nav-link" id="link-medicines"><%= t('nav_medicines') %></a></li>
          <li><a href="/diseases" class="nav-link" id="link-diseases"><%= t('nav_diseases') %></a></li>
          <% if (user) { %>
            <li><a href="/favorites" class="nav-link" id="link-favorites"><%= t('nav_favorites') %></a></li>
          <% } %>
          <li><a href="/compare" class="nav-link" id="link-compare"><%= t('nav_compare') %></a></li>
        </ul>
      </nav>

      <!-- Harakatlar paneli (Mavzu, Til, Profil) -->
      <div class="navbar-actions">
        <!-- Mavzu (Dark Mode) -->
        <button class="action-btn" id="theme-toggle-btn" aria-label="Mavzuni o'zgartirish">
          <!-- Sun (Light Mode) Icon -->
          <svg class="sun-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: <%= theme === 'dark' ? 'block' : 'none' %>;"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <!-- Moon (Dark Mode) Icon -->
          <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: <%= theme === 'dark' ? 'none' : 'block' %>;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>

        <!-- Til Almashtirgich -->
        <button class="action-btn lang-btn" id="lang-toggle-btn" aria-label="Tilni o'zgartirish"><%= lang === 'uz' ? 'EN' : 'UZ' %></button>

        <!-- Foydalanuvchi Profili -->
        <div class="user-profile-widget" id="user-profile-widget">
          <% if (!user) { %>
            <!-- Kirilmagan holat -->
            <button class="login-trigger-btn" id="login-trigger-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path><polyline points="10 17 15 12 10 7"></polyline><line x1="15" y1="12" x2="3" y2="12"></line></svg>
              <span><%= t('btn_login') %></span>
            </button>
          <% } else { %>
            <!-- Kirilgan holat -->
            <div id="user-logged-in-widget">
              <button class="user-avatar-btn" id="user-avatar-btn">
                <div class="avatar-circle" id="user-avatar-initial"><%= user.name.charAt(0).toUpperCase() %></div>
                <span class="avatar-name" id="user-avatar-name"><%= user.name %></span>
              </button>
              
              <!-- Profil Dropdown -->
              <div class="profile-dropdown" id="profile-dropdown">
                <a href="/profile" class="dropdown-link" id="drop-profile">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                  <%= t('drop_profile') %>
                </a>
                <% if (user.role === 'admin') { %>
                  <a href="/admin" class="dropdown-link admin-only" id="drop-admin">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><line x1="9" y1="3" x2="9" y2="21"></line></svg>
                    <%= t('drop_admin') %>
                  </a>
                <% } %>
                <a href="/auth/logout" class="dropdown-link logout-btn" id="drop-logout">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                  <%= t('drop_logout') %>
                </a>
              </div>
            </div>
          <% } %>
        </div>

        <!-- Hamburger tugma mobil uchun -->
        <button class="menu-toggle" id="menu-toggle" aria-label="Menyuni ochish/yopish">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        </button>
      </div>
    </div>
  </header>

  <!-- --- DINAMIK KONTENT SAHNSI --- -->
  <main id="app-content" class="main-content">
